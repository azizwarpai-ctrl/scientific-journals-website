# ===========================================================================
# .env.example — Copy to .env and fill in your values
# ===========================================================================

# --- Local Application Database ---
DATABASE_URL="mysql://root:root@127.0.0.1:3306/scientific_journals_db"

DATABASE_HOST="127.0.0.1"
DATABASE_PORT="3306"
DATABASE_NAME="scientific_journals_db"
DATABASE_USER="root"
DATABASE_PASSWORD="<YOUR_DB_PASSWORD>"

# --- Application ---
# Public, canonical origin (no trailing slash). Used for canonical <link>
# tags, sitemap.xml, and robots.txt. In production: https://digitopub.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Required in production. MUST be at least 32 bytes — getJwtSecret() throws
# at runtime if missing or shorter. Generate with: openssl rand -base64 48
JWT_SECRET="<GENERATE_A_STRONG_SECRET>"
# Bearer token gating /api/ojs/sync. Required for the cron endpoint to
# accept requests; the endpoint also serializes runs via a 5-minute lock.
CRON_SECRET="<GENERATE_A_STRONG_SECRET>"

MAX_FILE_SIZE_MB="50"
ALLOWED_FILE_TYPES="pdf,doc,docx,txt,jpg,png"
UPLOAD_DIR="./uploads"

# --- Object storage (Initiative B — article audio) ---
# S3-compatible storage for manager-uploaded audio files. Default target is
# Cloudflare R2; AWS S3, MinIO, or any other S3-compatible bucket also works.
# All five values are required when the audio upload route is in use; they
# are read at first call by src/lib/storage/index.ts and the read throws if
# any are missing — never commit real values to source.
#
# Cloudflare R2 example:
#   S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
#   S3_REGION="auto"
#   S3_BUCKET="digitopub-audio"
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional. Defaults to true (R2 / MinIO require path-style URLs). Set
# "false" only for AWS S3 with virtual-host style.
S3_FORCE_PATH_STYLE="true"

OJS_SYNC_ENABLED="false"

# --- OJS Database (fill in to enable OJS data on homepage) ---
OJS_DATABASE_HOST="<OJS_DB_HOST>"
OJS_DATABASE_PORT="3306"
OJS_DATABASE_NAME="<OJS_DB_NAME>"
OJS_DATABASE_USER="<OJS_DB_USER>"
OJS_DATABASE_PASSWORD="<OJS_DB_PASSWORD>"
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Admin Credentials (for init/seeding) ---
ADMIN_EMAIL="<ADMIN_EMAIL>"
ADMIN_PASSWORD="<ADMIN_PASSWORD>"
SUPPORT_EMAIL="<SUPPORT_EMAIL>"
SUPPORT_PASSWORD="<SUPPORT_PASSWORD>"

# --- OJS Base URL (public URL of the OJS installation) ---
# End-state: https://journals.digitopub.com (a DNS alias + SSL on the same
# SiteGround server that already hosts OJS — no file migration). The actual
# production value is set at deploy time after the cutover (gated on T5);
# do NOT bake production hosts into source.
OJS_BASE_URL=https://journals.digitopub.com
# Public-facing variant for browser links. Defaults to OJS_BASE_URL when
# unset. Inline into the client bundle by prefixing NEXT_PUBLIC_*.
PUBLIC_OJS_BASE_URL=https://journals.digitopub.com
NEXT_PUBLIC_OJS_BASE_URL=https://journals.digitopub.com

# --- OJS PDF Bridge (optional; bypasses payment plugin / WAF interstitials) ---
# OJS_API_KEY MUST match the value set in the OJS install's config.inc.php
# under [digitopub] api_key, or the OJS_API_KEY env var on the OJS server.
# Single-quote when exporting in a shell — the key may contain $, ], etc.
OJS_API_KEY=
# Full URL to the bridge endpoint. If unset, derived from OJS_BASE_URL.
# Also accepts OJS_PDF_BRIDGE_URL (legacy alias).
OJS_BRIDGE_URL=https://journals.digitopub.com/ojs/ojs-pdf-bridge.php

# --- Apex Scholar metadata kill switch ---
# When NOT exactly "true", the apex emits no Highwire `citation_*` tags. The
# OJS host is the sole Google-Scholar record; the apex defers to it via
# `<link rel="canonical">`. Flip with intent only.
EMIT_SCHOLAR_CITATION_META=false

# Email (SMTP) Configuration
# Used when OTP_DELIVERY_METHOD=email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@digitopub.com
SMTP_PASSWORD=your_secure_password
SMTP_FROM_EMAIL="\"DigitoPub Security\" <no-reply@digitopub.com>"

# ===========================================================================
# UIET-P1 — ORCID Public-User Identity & Engagement Tracking
# ===========================================================================
# Required in production. In dev, blanks fall back to dev defaults with a
# console warning.
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/auth/orcid/callback when blank.
ORCID_REDIRECT_URI=

# HMAC secrets — generate each with: openssl rand -base64 64
IDENTITY_COOKIE_SECRET=
ORCID_STATE_SECRET=
EVENT_IP_HASH_SALT_SEED=

# Feature flag — when "true", digitopub writes ORCID iDs into OJS
# user_settings on first email-match login. This is the ONLY path
# by which digitopub writes to the OJS database. Default OFF in
# production, ON in development.
ENABLE_ORCID_OJS_BACKFILL=true

# Master switch for the UIET-P1 surface area (consent banner, login
# modal, metric writes, account pages). When "false", existing public
# behavior is unchanged. Default "false".
UIET_P1_ENABLED=true

# Google Scholar discovery metadata (Option A vs Option B).
# Controls whether digitopub emits Google-Scholar-discovery metadata for
# article pages: the Highwire "citation_*" meta tags AND the ScholarlyArticle
# JSON-LD.
#
#   false (PRODUCTION DEFAULT — "Option A": OJS owns the Scholar record):
#     digitopub emits NO citation_* tags and NO ScholarlyArticle JSON-LD, so it
#     does not compete with the canonical OJS copy at submitmanager.com in
#     Google Scholar. Normal Google Search presence (title/description/
#     canonical/OpenGraph) and the human-facing inline PDF viewer are unaffected.
#
#   true ("Option B": digitopub as the Scholar system of record):
#     digitopub emits the full citation_* set + ScholarlyArticle JSON-LD, and
#     citation_pdf_url points at the real OJS download URL (never at /api/...).
EMIT_SCHOLAR_CITATION_META=false

