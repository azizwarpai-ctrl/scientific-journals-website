# ===========================================================================
# .env.example — Copy to .env and fill in your values
# ===========================================================================

# --- Local Application Database ---
DATABASE_URL="mysql://root:root@127.0.0.1:3306/scientific_journals_db"

DATABASE_HOST="127.0.0.1"
DATABASE_PORT="3306"
DATABASE_NAME="scientific_journals_db"
DATABASE_USER="root"
DATABASE_PASSWORD="<YOUR_DB_PASSWORD>"

# --- Application ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JWT_SECRET="<GENERATE_A_STRONG_SECRET>"

MAX_FILE_SIZE_MB="50"
ALLOWED_FILE_TYPES="pdf,doc,docx,txt,jpg,png"
UPLOAD_DIR="./uploads"

OJS_SYNC_ENABLED="false"

# --- OJS Database (fill in to enable OJS data on homepage) ---
OJS_DATABASE_HOST="<OJS_DB_HOST>"
OJS_DATABASE_PORT="3306"
OJS_DATABASE_NAME="<OJS_DB_NAME>"
OJS_DATABASE_USER="<OJS_DB_USER>"
OJS_DATABASE_PASSWORD="<OJS_DB_PASSWORD>"
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Admin Credentials (for init/seeding) ---
ADMIN_EMAIL="<ADMIN_EMAIL>"
ADMIN_PASSWORD="<ADMIN_PASSWORD>"
SUPPORT_EMAIL="<SUPPORT_EMAIL>"
SUPPORT_PASSWORD="<SUPPORT_PASSWORD>"

# --- OJS Base URL (public URL of the OJS installation) ---
OJS_BASE_URL=https://submitmanager.com

# --- OJS PDF Bridge (optional; bypasses payment plugin / WAF interstitials) ---
# OJS_API_KEY MUST match the value set in submitmanager.com's config.inc.php
# under [digitopub] api_key, or the OJS_API_KEY env var on the OJS server.
# Single-quote when exporting in a shell — the key may contain $, ], etc.
OJS_API_KEY=
# Full URL to the bridge endpoint. If unset, derived from OJS_BASE_URL.
# Also accepts OJS_PDF_BRIDGE_URL (legacy alias).
OJS_BRIDGE_URL=https://submitmanager.com/ojs/ojs-pdf-bridge.php

# Email (SMTP) Configuration
# Used when OTP_DELIVERY_METHOD=email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@digitopub.com
SMTP_PASSWORD=your_secure_password
SMTP_FROM_EMAIL="DigitoPub Security" <no-reply@digitopub.com>

