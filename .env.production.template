# =====================================================
# DATABASE (MySQL/MariaDB) — REQUIRED
# =====================================================
# Used by Prisma ORM. Must point to your production database.
DATABASE_URL="mysql://<user>:<password>@<host>:<port>/scientific_journals_db"

# Individual credentials (Optional, but good for reference/scripts)
DATABASE_HOST="<host>"
DATABASE_PORT="3306"
DATABASE_NAME="scientific_journals_db"
DATABASE_USER="<user>"
DATABASE_PASSWORD="<password>"

# =====================================================
# AUTHENTICATION — REQUIRED
# =====================================================
# Used by jose for JWT generation and validation in Next.js Middleware and Hono API.
# Generate a strong 64-character secret, e.g., using `openssl rand -base64 64`
JWT_SECRET="<your_secure_random_jwt_secret>"

# =====================================================
# APPLICATION & SECURITY — REQUIRED
# =====================================================
# Tells Next.js to optimize for production
NODE_ENV="production"

# The public facing URL of your application (Used by Hono RPC client `hc`)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Important for Hono API CORS! 
# Comma-separated list of origins allowed to interact with the API.
ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# =====================================================
# OJS CONFIGURATION (Optional: If using OJS)
# =====================================================
# OPTION A: HTTP Proxy (preferred for shared hosting — no Remote MySQL needed)
# Deploy submit_manger_api/api.php + config.php + .htaccess to SiteGround.
# The API key is sent ONLY via the X-API-KEY header (never as a URL param).
# IMPORTANT: Rotate the API key after deployment since the old key is in git history.
OJS_API_URL="https://submitmanager.com/api/api.php"
OJS_API_KEY="dgtpub_ojs_2026_k9x7m4"
OJS_PDF_BRIDGE_URL="https://submitmanager.com/ojs/ojs-pdf-bridge.php"
PUBLIC_OJS_BASE_URL="https://submitmanager.com/ojs"

# OPTION B: Direct MySQL (requires Remote MySQL + IP whitelisting)
# OJS_DATABASE_HOST="<ojs_host>"
# OJS_DATABASE_PORT="3306"
# OJS_DATABASE_NAME="ojs_db"
# OJS_DATABASE_USER="<ojs_readonly_user>"
# OJS_DATABASE_PASSWORD="<ojs_password>"

# Synchronization toggles (Used by background cron jobs if enabled)
OJS_SYNC_ENABLED="true"
OJS_SYNC_INTERVAL_MINUTES="360"

# =====================================================
# FILE UPLOADS (Optional)
# =====================================================
MAX_FILE_SIZE_MB="50"
ALLOWED_FILE_TYPES="pdf,doc,docx,txt,jpg,png"
UPLOAD_DIR="./uploads"

# =====================================================
# SEEDING CREDENTIALS (Required for first-time init)
# =====================================================
ADMIN_EMAIL="<admin_email>"
ADMIN_PASSWORD="<admin_password>"
SUPPORT_EMAIL="<support_email>"
SUPPORT_PASSWORD="<support_password>"

# =====================================================
# RUNTIME INITIALIZATION (Required for init.ts)
# =====================================================
# Set to "true" to enable automatic DB migration + seeding on startup.
# Should only be "true" during the initial deployment or after schema changes.
ALLOW_PROD_DB_INIT="false"

# Controls how OTP verification codes are delivered.
# Options: "console" (dev only), "email" (requires provider), "disabled" (fail-closed)
# In production, "disabled" is the safe default until an email provider is approved.
OTP_DELIVERY_METHOD="disabled"
