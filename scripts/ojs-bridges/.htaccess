# ─── Authorization header passthrough ────────────────────────────────────
#
# Apache + mod_php frequently strips the Authorization header before the
# bridge PHP sees it. Without this rule, every bridge call from DigitoPub
# arrives with an empty Bearer and the bridge returns 401 AUTH_REQUIRED.
#
# Deploy this file next to `ojs-pdf-bridge.php` (same directory). If your
# OJS root already has a broader .htaccess, merge these two rules into it
# instead of stacking files.
#
# Scope: applies ONLY to the bridge. The main OJS rewrite rules are not
# altered — this file lives in the bridge's own directory.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%1,L]
</IfModule>

# Some PHP-FPM setups need CGIPassAuth as well.
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Deny anything except the bridge script itself.
<Files "*">
    Require all denied
</Files>
<Files "ojs-pdf-bridge.php">
    Require all granted
</Files>
