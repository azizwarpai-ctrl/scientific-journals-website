{
  "name": "digitopub",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "prisma generate && node -e \"if(process.env.DATABASE_URL){const{execSync}=require('child_process');console.log('Running migrations...');execSync('prisma migrate deploy',{stdio:'inherit'})}else{console.log('Skipping migrations (no DATABASE_URL)')}\" && next build",
    "dev": "next dev",
    "start": "npx prisma migrate deploy && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "mysql -u $DATABASE_USER -p$DATABASE_PASSWORD $DATABASE_NAME < scripts/001_create_tables.sql",
    "db:seed": "mysql -u $DATABASE_USER -p$DATABASE_PASSWORD $DATABASE_NAME < scripts/002_insert_sample_data.sql",
    "ojs:sync": "bun run scripts/ojs-sync-cron.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
