# =====================================================
# 🌐 FRONTEND CONFIGURATION (NEXT.JS)
# =====================================================

# URL of the PHP Backend API (Crucial for Frontend)
# Local Development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL="http://localhost:8000"

# URL of the Frontend Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OJS URL (For external links)
NEXT_PUBLIC_OJS_URL="https://submitmanger.com"

# =====================================================
# 🗄️ DATABASE CONFIGURATION (PRISMA / SCRIPTS)
# =====================================================

# Used by Prisma and Node.js maintenance scripts
# Docker Default: Port 3307
DATABASE_URL="mysql://app_user:apppassword@localhost:3307/scientific_journals"

# Individual parameters (Used by some legacy scripts)
DATABASE_HOST="localhost"
DATABASE_PORT="3307"
DATABASE_NAME="scientific_journals"
DATABASE_USER="app_user"
DATABASE_PASSWORD="apppassword"

# =====================================================
# 🔄 OJS INTEGRATION (READ-ONLY)
# =====================================================

OJS_SYNC_ENABLED="true"
OJS_DATABASE_HOST="submitmanger.com"
OJS_DATABASE_NAME="ojs_db"
OJS_DATABASE_USER="ojs_readonly"
# OJS_DATABASE_PASSWORD="secure_password" # Uncomment and set if available

# =====================================================
# ⚙️ APPLICATION SETTINGS
# =====================================================

NODE_ENV="development"
JWT_SECRET="CiSg2BbuCqvSBHiaPVj/nTDxCqtoUJgJHpixjxNw25Q="
